{
  "name": "bloomtech-hub-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand --detectOpenHandles --forceExit",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:setup": "node scripts/setup-database.js",
    "db:seed": "node scripts/seed-data.js",
    "db:migrate-data": "node scripts/migrate-data.js",
    "db:reset": "npm run migrate:undo:all && npm run migrate && npm run db:seed"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.2.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2",
    "nodemailer": "^7.0.5",
    "pdfkit": "^0.17.1",
    "sanitize-html": "^2.17.0",
    "sequelize": "^6.37.7",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "xss-clean": "^0.1.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "babel-jest": "^30.0.5",
    "cross-env": "^7.0.3",
    "jest": "^30.0.5",
    "nodemon": "^3.0.1",
    "sinon": "^21.0.0",
    "supertest": "^7.1.3"
  }
}
