# Database Configuration
# NOTE: the app reads DB_PASS (see sequelize_models/config.js), not DB_PASSWORD.
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bloomtech_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Legacy Gmail Configuration (for backward compatibility)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:8081

# Backend URL (for payment redirects)
BACKEND_URL=http://localhost:5000

# Admin Email
ADMIN_EMAIL=admin@bloomtech.com

# M-Pesa Configuration
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/payments/mpesa/callback

# Pesapal Configuration
# Obtain credentials from your Pesapal dashboard. Do NOT commit real values.
PESAPAL_CONSUMER_KEY=your_pesapal_consumer_key
PESAPAL_CONSUMER_SECRET=your_pesapal_consumer_secret
PESAPAL_CALLBACK_URL=https://your-domain.com/api/payments/pesapal/callback
# Sandbox: https://cybqa.pesapal.com/pesapalv3/api  |  Live: https://pay.pesapal.com/v3/api
PESAPAL_API_ENDPOINT=https://cybqa.pesapal.com/pesapalv3/api

# Flutterwave Configuration (for future integration)
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/api/payments/flutterwave/webhook

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/lovable-uploads

