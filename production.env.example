# Production Environment Variables for Bloomtech Hub
# Copy this file to backend/.env and update with your actual values

# Database Configuration (from your hosting provider)
DB_HOST=localhost
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=3306

# JWT Configuration (generate a strong secret)
JWT_SECRET=your-super-secure-jwt-secret-key-here-make-it-long-and-random

# Email Configuration (using your domain emails)
SMTP_HOST=mail.bloomtechub.com
SMTP_PORT=587
# true for port 465 (implicit SSL), false for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=noreply@bloomtechub.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@bloomtechub.com

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (your domain)
FRONTEND_URL=https://bloomtechub.com

# Admin Email (internal notifications: contact form, quote requests)
ADMIN_EMAIL=admin@bloomtechub.com

# Support Email (customer-facing reply-to on transactional emails)
SUPPORT_EMAIL=support@bloomtechub.com

# Payment Configuration (if needed later)
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_ENVIRONMENT=live

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/lovable-uploads

# M-Pesa Configuration (if needed later)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://bloomtechub.com/api/payments/mpesa/callback
