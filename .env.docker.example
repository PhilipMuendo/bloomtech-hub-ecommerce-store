# Copy to `.env` (same directory as docker-compose.yml) and fill in real values.
# docker compose automatically reads a file named `.env` for ${VAR} substitution.

# --- Database ---
DB_NAME=bloomtech_db
DB_USER=bloomtech
DB_PASS=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# --- App ---
# Public URL the site is served from (used for email links / payment redirects).
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
FRONTEND_PORT=8080

# Secret for signing JWTs — use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Pesapal (optional) ---
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=
PESAPAL_API_ENDPOINT=https://cybqa.pesapal.com/pesapalv3/api
