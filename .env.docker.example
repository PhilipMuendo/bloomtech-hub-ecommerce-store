# Copy to `.env` (same directory as docker-compose.yml) and fill in real values.
# docker compose automatically reads a file named `.env` for ${VAR} substitution.

# --- Database ---
DB_NAME=bloomtech_db
DB_USER=bloomtech
DB_PASS=change-me-strong-password
DB_ROOT_PASSWORD=change-me-strong-root-password

# --- App ---
# Public URL the site is served from (used for email links / payment redirects).
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
FRONTEND_PORT=8080

# Secret for signing JWTs — use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# --- Email (optional) ---
# SMTP_USER/SMTP_FROM = the "noreply@" mailbox system mail is sent from.
# ADMIN_EMAIL = internal inbox where contact-form/quote notifications land.
# SUPPORT_EMAIL = customer-facing reply-to shown on transactional emails.
SMTP_HOST=
SMTP_PORT=587
# true for port 465 (implicit SSL), false/blank for port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=admin@bloomtechub.com
SUPPORT_EMAIL=support@bloomtechub.com

# --- Pesapal (optional) ---
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_CALLBACK_URL=
PESAPAL_API_ENDPOINT=https://cybqa.pesapal.com/pesapalv3/api

# --- Google OAuth (optional) ---
# One client ID, used by both sides: the backend verifies Google ID token
# audience against it (authController.js), and docker-compose passes it to
# the frontend build as VITE_GOOGLE_CLIENT_ID (see docker-compose.yml).
# They must be the same value or Google sign-in fails at backend verification.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
